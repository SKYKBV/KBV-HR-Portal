<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR Portal - Leave & Shift Swap</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background-color: #f3f4f6;
        }
        .glass-effect {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .form-input {
            width: 100%;
            border-radius: 0.75rem;
            border-color: #d1d5db;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            font-size: 0.875rem;
            line-height: 1.25rem;
            padding: 0.75rem 1rem;
            background-color: #f9fafb;
            transition: all 0.2s;
        }
        .form-input:focus {
            outline: 2px solid transparent;
            outline-offset: 2px;
            border-color: #4f46e5;
            --tw-ring-color: #4f46e5;
            box-shadow: var(--tw-ring-offset-shadow, 0 0 #0000), var(--tw-ring-shadow, 0 0 #0000), 0 10px 15px -3px rgba(79, 70, 229, 0.1);
        }
        .form-input-readonly {
            width: 100%;
            border-radius: 0.75rem;
            border-color: #e5e7eb;
            box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
            font-size: 0.875rem;
            line-height: 1.25rem;
            padding: 0.75rem 1rem;
            background-color: #e5e7eb;
            color: #6b7280;
            cursor: not-allowed;
        }
        .form-label {
            display: block;
            font-size: 0.875rem;
            line-height: 1.25rem;
            font-weight: 500;
            color: #374151;
            margin-bottom: 0.25rem;
            margin-left: 0.25rem;
        }
        .tab-btn {
            flex: 1 1 0%;
            padding-top: 1rem;
            padding-bottom: 1rem;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            text-align: center;
            font-weight: 500;
            font-size: 0.875rem;
            transition-property: all;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 300ms;
            border-radius: 0.75rem;
            position: relative;
        }
        .tab-btn.active {
            background-color: #4f46e5;
            color: #ffffff;
            box-shadow: 0 10px 15px -3px rgba(165, 180, 252, 0.3);
            transform: scale(1.03);
            z-index: 10;
        }
        .tab-btn.inactive {
            color: #6b7280;
        }
        .tab-btn.inactive:hover {
            color: #374151;
            background-color: #f3f4f6;
        }
        input[type="file"]::file-selector-button {
            margin-right: 1rem;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            border-width: 0px;
            font-size: 0.875rem;
            font-weight: 600;
            background-color: #e0e7ff;
            color: #4338ca;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        input[type="file"]::file-selector-button:hover {
            background-color: #c7d2fe;
        }
        .fade-in { animation: fadeIn 0.4s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* Loading Overlay Style */
        .loader-overlay {
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body class="min-h-screen pb-12">

  <!-- Header -->
 <header class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-4">
                    
                    <!-- โลโก้ รูปเครื่องบิน 3 สี (สร้างจากโค้ด SVG) -->
                    <div class="flex items-center justify-center">
                        <svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <defs>
                                <!-- กำหนดสี 3 ส่วน: แดง น้ำเงิน ดำ (กำหนดองศา x1,y1 ให้ออกมาเป็นแนวเฉียงนิดๆ) -->
                                <linearGradient id="plane-colors" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <!-- ส่วนที่ 1: สีแดง -->
                                    <stop offset="33%" stop-color="#ef4444" /> 
                                    <!-- ส่วนที่ 2: สีน้ำเงิน -->
                                    <stop offset="33%" stop-color="#3b82f6" /> 
                                    <stop offset="66%" stop-color="#3b82f6" />
                                    <!-- ส่วนที่ 3: สีดำ -->
                                    <stop offset="66%" stop-color="#111827" /> 
                                    <stop offset="100%" stop-color="#111827" />
                                </linearGradient>
                            </defs>
                            <!-- เรียกใช้สีจาก Gradient ที่ตั้งค่าไว้ที่ fill="url(#plane-colors)" -->
                            <path fill="url(#plane-colors)" d="M21,16V14L13,9V3.5C13,2.67 12.33,2 11.5,2C10.67,2 10,2.67 10,3.5V9L2,14V16L10,13.5V19L8,20.5V22L11.5,21L15,22V20.5L13,19V13.5L21,16Z" />
                        </svg>
                    </div>

                    <!-- เส้นคั่นและข้อความ -->
                    <div class="border-l-2 border-gray-200 pl-4 py-1">
                        <h1 class="text-lg font-bold text-gray-900 leading-tight">SKY KBV HR Portal</h1>
                        <p class="text-xs text-gray-500 mt-0.5">Leave & Shift Swap System</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="hidden sm:flex items-center gap-2 text-sm text-gray-600">
                        <i class="fa-regular fa-clock"></i>
                        <span id="currentTime">01:23 u.</span>
                    </div>
                    <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 cursor-pointer hover:bg-indigo-200 transition-colors">
                        <i class="fa-regular fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </header>
    
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
        
        <!-- Tab Navigation -->
        <div class="bg-white p-2 rounded-2xl shadow-sm mb-8 flex flex-col sm:flex-row gap-2 max-w-2xl mx-auto">
            <button id="tab-leave" onclick="switchTab('leave')" class="tab-btn active">
                <i class="fa-solid fa-calendar-minus mr-2"></i> ฟังก์ชั่น 1: แจ้งลางาน
            </button>
            <button id="tab-swap" onclick="switchTab('swap')" class="tab-btn inactive">
                <i class="fa-solid fa-arrow-right-arrow-left mr-2"></i> ฟังก์ชั่น 2: สลับวันทำงาน
            </button>
        </div>

        <!-- Form 1: Leave Request -->
        <div id="form-leave-container" class="glass-effect rounded-3xl p-6 sm:p-10 shadow-xl fade-in max-w-3xl mx-auto">
            <div class="mb-8 border-b border-gray-100 pb-6">
                <h2 class="text-2xl font-bold text-gray-800"><i class="fa-regular fa-calendar-check text-indigo-600 mr-2"></i> แบบฟอร์มขออนุญาตลา</h2>
                <p class="text-gray-500 mt-2 text-sm">กรุณากรอกข้อมูลให้ครบถ้วนเพื่อความรวดเร็วในการอนุมัติ</p>
            </div>

            <form id="leave-form" onsubmit="submitLeave(event)" class="space-y-6">
                <!-- ข้อมูลพนักงาน -->
                <div class="bg-indigo-50/50 rounded-2xl p-5 border border-indigo-100/50">
                    <h3 class="text-sm font-bold text-indigo-800 mb-4 uppercase tracking-wider">1. ข้อมูลพนักงาน</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="form-label">รหัสพนักงาน <span class="text-red-500">*</span></label>
                            <select id="l_emp_id" required class="form-input" onchange="lookupEmployee('l_emp_id', 'l_name', 'l_position')">
                                <option value="" disabled selected>กำลังโหลดรายชื่อพนักงาน...</option>
                            </select>
                        </div>
                        <div class="md:col-span-1"></div>
                        
                        <div>
                            <label class="form-label">ชื่อ - สกุล</label>
                            <input type="text" id="l_name" class="form-input-readonly" readonly placeholder="ดึงข้อมูลอัตโนมัติ">
                        </div>
                        <div>
                            <label class="form-label">ตำแหน่ง</label>
                            <input type="text" id="l_position" class="form-input-readonly" readonly placeholder="ดึงข้อมูลอัตโนมัติ">
                        </div>
                    </div>
                </div>

                <!-- รายละเอียดการลา -->
                <div class="bg-white rounded-2xl p-5 border border-gray-100">
                    <h3 class="text-sm font-bold text-gray-800 mb-4 uppercase tracking-wider">2. รายละเอียดการลา</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="form-label">วันที่ต้องการจะขอลา <span class="text-red-500">*</span></label>
                            <input type="date" id="l_date" required class="form-input">
                        </div>
                        <div>
                            <label class="form-label">เวลาปฏิบัติงาน (กะทำงาน) <span class="text-red-500">*</span></label>
                            <select id="l_shift" required class="form-input">
                                <option value="" disabled selected>เลือกกะทำงาน</option>
                                <option value="กะเช้า">กะเช้า (Morning Shift)</option>
                                <option value="กะดึก">กะดึก (Night Shift)</option>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label">ประเภทการลา <span class="text-red-500">*</span></label>
                            <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-2">
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลาป่วย" required class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลาป่วย</div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลากิจ" class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลากิจ</div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลาพักผ่อน" class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลาพักผ่อน</div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลาวันเกิด" class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลาวันเกิด</div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลาคลอด" class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลาคลอด</div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="l_type" value="ลาไม่รับค่าจ้าง" class="peer sr-only">
                                    <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 hover:bg-gray-50 peer-checked:border-indigo-500 peer-checked:ring-1 peer-checked:ring-indigo-500 peer-checked:bg-indigo-50 transition-all text-sm font-medium text-gray-700 text-center">ลาไม่รับค่าจ้าง</div>
                                </label>
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label">เหตุผล <span class="text-red-500">*</span></label>
                            <textarea id="l_reason" required rows="3" class="form-input resize-none" placeholder="ระบุเหตุผลการลา..."></textarea>
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label">เอกสารประกอบการลา (ถ้ามี)</label>
                            <p class="text-xs text-gray-400 mb-2">ไฟล์จะถูกอัปโหลดอัตโนมัติไปเก็บที่ Google Drive โดยแบ่งตามเดือนและปีที่คุณขอลาพักผ่อน</p>
                            <input type="file" id="l_file" class="form-input bg-white w-full border border-dashed border-gray-300 p-2 text-gray-500" accept=".pdf,.jpg,.jpeg,.png">
                        </div>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-4 rounded-xl shadow-lg transform transition duration-200 hover:-translate-y-1 text-lg">
                        <i class="fa-solid fa-paper-plane mr-2"></i> ส่งคำขอลาพัก
                    </button>
                </div>
            </form>
        </div>

        <!-- Form 2: Shift Swap -->
        <div id="form-swap-container" class="glass-effect rounded-3xl p-6 sm:p-10 shadow-xl hidden fade-in max-w-4xl mx-auto">
            <div class="mb-8 border-b border-gray-100 pb-6">
                <h2 class="text-2xl font-bold text-gray-800"><i class="fa-solid fa-users text-purple-600 mr-2"></i> แบบฟอร์มขอสลับวันทำงาน (แลกกะ)</h2>
                <p class="text-gray-500 mt-2 text-sm">ระบุข้อมูลผู้ขอแลกและผู้ที่มาทำงานแทนให้ชัดเจน</p>
            </div>

            <form id="swap-form" onsubmit="submitSwap(event)" class="space-y-8">
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- ส่วนของผู้ขอแลก (เรา) -->
                    <div class="bg-blue-50/50 rounded-2xl p-5 border border-blue-100">
                        <div class="flex items-center mb-4">
                            <div class="w-8 h-8 rounded-full bg-blue-200 text-blue-700 flex items-center justify-center font-bold mr-3">1</div>
                            <h3 class="font-bold text-blue-800">สำหรับพนักงานที่ขอแลกวันทำงาน (ตัวคุณ)</h3>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <label class="form-label">รหัสพนักงาน <span class="text-red-500">*</span></label>
                                <select id="s1_emp_id" required class="form-input border-blue-200 focus:border-blue-500 focus:ring-blue-500" onchange="lookupEmployee('s1_emp_id', 's1_name', 's1_position')">
                                    <option value="" disabled selected>เลือกรหัสพนักงานของคุณ</option>
                                </select>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="form-label">ชื่อ - สกุล</label>
                                    <input type="text" id="s1_name" class="form-input-readonly bg-blue-100/50" readonly placeholder="อัตโนมัติ">
                                </div>
                                <div>
                                    <label class="form-label">ตำแหน่ง</label>
                                    <input type="text" id="s1_position" class="form-input-readonly bg-blue-100/50" readonly placeholder="อัตโนมัติ">
                                </div>
                            </div>
                            <div class="mt-4 pt-4 border-t border-blue-200">
                                <label class="form-label">วันที่ <span class="text-blue-600 font-bold underline">เรามาทำงานแทนเพื่อน</span> <span class="text-red-500">*</span></label>
                                <input type="date" id="s1_date" required class="form-input border-blue-200 focus:border-blue-500 focus:ring-blue-500">
                            </div>
                            <div>
                                <label class="form-label">เวลาปฏิบัติงาน (กะทำงาน) <span class="text-red-500">*</span></label>
                                <select id="s1_shift" required class="form-input border-blue-200 focus:border-blue-500 focus:ring-blue-500">
                                    <option value="" disabled selected>เลือกกะทำงาน</option>
                                    <option value="กะเช้า">กะเช้า</option>
                                    <option value="กะดึก">กะดึก</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- ส่วนของเพื่อนที่มาแทน -->
                    <div class="bg-emerald-50/50 rounded-2xl p-5 border border-emerald-100">
                        <div class="flex items-center mb-4">
                            <div class="w-8 h-8 rounded-full bg-emerald-200 text-emerald-700 flex items-center justify-center font-bold mr-3">2</div>
                            <h3 class="font-bold text-emerald-800">สำหรับเพื่อนที่มาทำงานแทนเรา</h3>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <label class="form-label">รหัสพนักงาน (เพื่อน) <span class="text-red-500">*</span></label>
                                <select id="s2_emp_id" required class="form-input border-emerald-200 focus:border-emerald-500 focus:ring-emerald-500" onchange="lookupEmployee('s2_emp_id', 's2_name', 's2_position')">
                                    <option value="" disabled selected>เลือกรหัสพนักงานเพื่อน</option>
                                </select>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="form-label">ชื่อ - สกุล</label>
                                    <input type="text" id="s2_name" class="form-input-readonly bg-emerald-100/50" readonly placeholder="อัตโนมัติ">
                                </div>
                                <div>
                                    <label class="form-label">ตำแหน่ง</label>
                                    <input type="text" id="s2_position" class="form-input-readonly bg-emerald-100/50" readonly placeholder="อัตโนมัติ">
                                </div>
                            </div>
                            <div class="mt-4 pt-4 border-t border-emerald-200">
                                <label class="form-label">วันที่ <span class="text-emerald-600 font-bold underline">เพื่อนมาทำงานแทนเรา</span> <span class="text-red-500">*</span></label>
                                <input type="date" id="s2_date" required class="form-input border-emerald-200 focus:border-emerald-500 focus:ring-emerald-500">
                            </div>
                            <div>
                                <label class="form-label">เวลาปฏิบัติงาน (กะทำงาน) <span class="text-red-500">*</span></label>
                                <select id="s2_shift" required class="form-input border-emerald-200 focus:border-emerald-500 focus:ring-emerald-500">
                                    <option value="" disabled selected>เลือกกะทำงาน</option>
                                    <option value="กะเช้า">กะเช้า</option>
                                    <option value="กะดึก">กะดึก</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- เหตุผลส่วนกลาง -->
                <div class="bg-white rounded-2xl p-5 border border-gray-100">
                    <label class="form-label">เหตุผลในการสลับวันทำงาน <span class="text-red-500">*</span></label>
                    <textarea id="s_reason" required rows="3" class="form-input resize-none" placeholder="ระบุเหตุผลความจำเป็น..."></textarea>
                </div>

                <div class="pt-2">
                    <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold py-4 rounded-xl shadow-lg transform transition duration-200 hover:-translate-y-1 text-lg">
                        <i class="fa-solid fa-right-left mr-2"></i> ส่งคำขอสลับวันทำงาน
                    </button>
                </div>
            </form>
        </div>

    </main>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 z-[110] loader-overlay flex items-center justify-center hidden">
        <div class="bg-white p-8 rounded-2xl shadow-2xl flex flex-col items-center gap-4 max-w-xs w-full mx-4">
            <svg class="animate-spin h-12 w-12 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="text-gray-700 font-medium text-center">กำลังส่งข้อมูลและบันทึกเอกสาร...</p>
        </div>
    </div>

    <!-- Custom Modal (Replacement for alert) -->
    <div id="customModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            
            <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md w-full p-6">
                <div>
                    <div id="modalIcon" class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100">
                        <i class="fa-solid fa-check text-2xl text-green-600"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-5">
                        <h3 class="text-xl leading-6 font-bold text-gray-900" id="modalTitle">สำเร็จ</h3>
                        <div class="mt-2">
                            <p class="text-sm text-gray-500" id="modalMessage">บันทึกข้อมูลเข้าสู่ระบบเรียบร้อยแล้ว</p>
                        </div>
                    </div>
                </div>
                <div class="mt-5 sm:mt-6">
                    <button type="button" onclick="closeModal()" class="inline-flex justify-center w-full rounded-xl border border-transparent shadow-sm px-4 py-3 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none sm:text-sm">
                        รับทราบ ปิดหน้าต่าง
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ข้อมูลพนักงานสำรอง (กรณีเปิดดูโค้ดนี้ภายนอกระบบ Google Apps Script)
        const localMockEmployees = [
            { id: "EMP001", name: "นาย สมชาย ใจดี", position: "Senior Software Engineer" },
            { id: "EMP002", name: "นางสาว วรรณา รักงาน", position: "UX/UI Designer" },
            { id: "EMP003", name: "นาย ธนา พาณิชย์", position: "Project Manager" },
            { id: "EMP004", name: "นาง สมรักษ์ ขยัน", position: "QA Tester" },
            { id: "EMP005", name: "นาย ก้องเกียรติ ยอดเยี่ยม", position: "DevOps Engineer" },
            { id: "EMP006", name: "นางสาว ลลิตา สวยงาม", position: "HR Specialist" }
        ];

        let employeeData = [];

        // ฟังก์ชันอัปเดตเวลาที่หัวข้อเว็บ
        function updateTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' });
            document.getElementById('currentTime').textContent = timeString + ' น.';
        }
        setInterval(updateTime, 1000);
        updateTime();

        // เมื่อโหลดหน้าเว็บเสร็จ ให้ไปดึงรายชื่อพนักงานจาก Google Sheet
        window.onload = function() {
            loadEmployeeList();
        };

        function loadEmployeeList() {
            if (typeof google !== 'undefined' && google.script && google.script.run) {
                // ดึงรายชื่อพนักงานจากหลังบ้าน Google Sheets
                google.script.run
                    .withSuccessHandler(onEmployeesLoaded)
                    .withFailureHandler(onLoadFailed)
                    .getEmployeeData();
            } else {
                // หากรันแบบ Local (เช่นบนหน้านี้) ให้โหลด Mock data แทน
                console.warn("Running in local mock environment.");
                onEmployeesLoaded(localMockEmployees);
            }
        }

        function onEmployeesLoaded(data) {
            employeeData = data || [];
            
            const l_dropdown = document.getElementById('l_emp_id');
            const s1_dropdown = document.getElementById('s1_emp_id');
            const s2_dropdown = document.getElementById('s2_emp_id');

            // เคลียร์ค่าเริ่มต้น
            l_dropdown.innerHTML = '<option value="" disabled selected>เลือกรหัสพนักงาน</option>';
            s1_dropdown.innerHTML = '<option value="" disabled selected>เลือกรหัสพนักงานของคุณ</option>';
            s2_dropdown.innerHTML = '<option value="" disabled selected>เลือกรหัสพนักงานเพื่อน</option>';

            if (employeeData.length === 0) {
                const opt = '<option value="" disabled>ไม่พบข้อมูลรายชื่อในชีท</option>';
                l_dropdown.innerHTML = opt;
                s1_dropdown.innerHTML = opt;
                s2_dropdown.innerHTML = opt;
                return;
            }

            employeeData.forEach(emp => {
                // นามสกุลตัดย่อเพื่อความกะทัดรัด
                const shortName = emp.name.split(' ')[1] ? emp.name.split(' ')[0] + ' ' + emp.name.split(' ')[1].charAt(0) + '.' : emp.name;
                const optionHtml = `<option value="${emp.id}">${emp.id} - ${shortName}</option>`;
                l_dropdown.insertAdjacentHTML('beforeend', optionHtml);
                s1_dropdown.insertAdjacentHTML('beforeend', optionHtml);
                s2_dropdown.insertAdjacentHTML('beforeend', optionHtml);
            });
        }

        function onLoadFailed(error) {
            showModal('เกิดข้อผิดพลาด', 'ไม่สามารถเชื่อมต่อข้อมูลพนักงานจาก Google Sheet ได้: ' + error, 'error');
        }

        // ระบบ Auto-lookup
        function lookupEmployee(selectId, nameId, posId) {
            const selectEl = document.getElementById(selectId);
            const empId = selectEl.value;
            
            const emp = employeeData.find(e => e.id === empId);
            if (emp) {
                document.getElementById(nameId).value = emp.name;
                document.getElementById(posId).value = emp.position;
            } else {
                document.getElementById(nameId).value = "";
                document.getElementById(posId).value = "";
            }
        }

        // สลับแท็บฟังก์ชัน 1 และ 2
        function switchTab(tab) {
            const btnLeave = document.getElementById('tab-leave');
            const btnSwap = document.getElementById('tab-swap');
            const formLeave = document.getElementById('form-leave-container');
            const formSwap = document.getElementById('form-swap-container');

            if (tab === 'leave') {
                btnLeave.className = "tab-btn active";
                btnSwap.className = "tab-btn inactive";
                formLeave.classList.remove('hidden');
                formSwap.classList.add('hidden');
            } else {
                btnSwap.className = "tab-btn active";
                btnLeave.className = "tab-btn inactive";
                formSwap.classList.remove('hidden');
                formLeave.classList.add('hidden');
            }
        }

        // ส่งคำขอลาพักผ่อน
        function submitLeave(event) {
            event.preventDefault();
            
            const fileInput = document.getElementById('l_file');
            const file = fileInput.files[0];
            
            showLoading(true);

            // หากมีการแนบไฟล์ ให้แปลงเป็น Base64 ก่อนส่งไปให้ Google Apps Script
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    sendLeaveData(e.target.result, file.name);
                };
                reader.onerror = function() {
                    showLoading(false);
                    showModal('เกิดข้อผิดพลาด', 'ไม่สามารถอ่านไฟล์ที่แนบได้ กรุณาลองใหม่อีกครั้ง', 'error');
                };
                reader.readAsDataURL(file); // แปลงไฟล์เป็น Data URL (Base64)
            } else {
                sendLeaveData(null, null);
            }
        }

        function sendLeaveData(fileData, fileName) {
            const formData = {
                empId: document.getElementById('l_emp_id').value,
                name: document.getElementById('l_name').value,
                position: document.getElementById('l_position').value,
                leaveDate: document.getElementById('l_date').value,
                shift: document.getElementById('l_shift').value,
                leaveType: document.querySelector('input[name="l_type"]:checked').value,
                reason: document.getElementById('l_reason').value,
                fileData: fileData,
                fileName: fileName
            };

            if (typeof google !== 'undefined' && google.script && google.script.run) {
                google.script.run
                    .withSuccessHandler(function(response) {
                        showLoading(false);
                        if (response.success) {
                            showModal('ส่งใบลาสำเร็จ', 'ระบบบันทึกการลาและอัปโหลดไฟล์ (ถ้ามี) เรียบร้อยแล้ว', 'success');
                            resetLeaveForm();
                        } else {
                            showModal('ล้มเหลว', 'ผิดพลาดจากระบบหลังบ้าน: ' + response.error, 'error');
                        }
                    })
                    .withFailureHandler(function(err) {
                        showLoading(false);
                        showModal('ล้มเหลว', 'ไม่สามารถเชื่อมต่อเครือข่าย Google ได้: ' + err, 'error');
                    })
                    .saveLeave(formData);
            } else {
                // หากรันแบบจำลองภายในโปรแกรมจำลอง
                setTimeout(() => {
                    showLoading(false);
                    showModal('จำลองการทำงานสำเร็จ', `[Mock] บันทึกข้อมูลการลาประเภท <b>${formData.leaveType}</b> เรียบร้อยแล้ว`, 'success');
                    resetLeaveForm();
                }, 1500);
            }
        }

        function resetLeaveForm() {
            document.getElementById('leave-form').reset();
            document.getElementById('l_name').value = '';
            document.getElementById('l_position').value = '';
        }

        // ส่งคำขอสลับวันทำงาน
        function submitSwap(event) {
            event.preventDefault();
            
            const s1_emp = document.getElementById('s1_emp_id').value;
            const s2_emp = document.getElementById('s2_emp_id').value;

            if (s1_emp === s2_emp) {
                showModal('เกิดข้อผิดพลาด', 'คุณไม่สามารถเลือกสลับวันทำงานกับตัวคุณเองได้ กรุณาเลือกรหัสพนักงานเพื่อนคนอื่น', 'error');
                return;
            }

            const formData = {
                s1_empId: s1_emp,
                s1_name: document.getElementById('s1_name').value,
                s1_position: document.getElementById('s1_position').value,
                s1_date: document.getElementById('s1_date').value,
                s1_shift: document.getElementById('s1_shift').value,
                
                s2_empId: s2_emp,
                s2_name: document.getElementById('s2_name').value,
                s2_position: document.getElementById('s2_position').value,
                s2_date: document.getElementById('s2_date').value,
                s2_shift: document.getElementById('s2_shift').value,
                
                reason: document.getElementById('s_reason').value
            };

            showLoading(true);

            if (typeof google !== 'undefined' && google.script && google.script.run) {
                google.script.run
                    .withSuccessHandler(function(response) {
                        showLoading(false);
                        if (response.success) {
                            showModal('ส่งสลับกะสำเร็จ', 'ระบบบันทึกคำขอสลับกะไปที่ Google Sheet เรียบร้อยแล้ว', 'success');
                            resetSwapForm();
                        } else {
                            showModal('ล้มเหลว', 'ผิดพลาดจากระบบหลังบ้าน: ' + response.error, 'error');
                        }
                    })
                    .withFailureHandler(function(err) {
                        showLoading(false);
                        showModal('ล้มเหลว', 'ไม่สามารถเชื่อมต่อเครือข่าย Google ได้: ' + err, 'error');
                    })
                    .saveSwap(formData);
            } else {
                setTimeout(() => {
                    showLoading(false);
                    showModal('จำลองการทำงานสำเร็จ', `[Mock] บันทึกคำขอสลับทำงานระหว่าง ${formData.s1_name} และ ${formData.s2_name} เรียบร้อยแล้ว`, 'success');
                    resetSwapForm();
                }, 1500);
            }
        }

        function resetSwapForm() {
            document.getElementById('swap-form').reset();
            document.getElementById('s1_name').value = '';
            document.getElementById('s1_position').value = '';
            document.getElementById('s2_name').value = '';
            document.getElementById('s2_position').value = '';
        }

        // ระบบหน้าต่างเตือนแจ้งผล (Modal)
        function showModal(title, message, type) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalMessage').innerHTML = message;
            
            const iconContainer = document.getElementById('modalIcon');
            if (type === 'success') {
                iconContainer.className = "mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100";
                iconContainer.innerHTML = '<i class="fa-solid fa-check text-2xl text-green-600"></i>';
            } else if (type === 'error') {
                iconContainer.className = "mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-100";
                iconContainer.innerHTML = '<i class="fa-solid fa-xmark text-2xl text-red-600"></i>';
            }

            document.getElementById('customModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('customModal').classList.add('hidden');
        }

        function showLoading(visible) {
            const overlay = document.getElementById('loadingOverlay');
            if (visible) {
                overlay.classList.remove('hidden');
            } else {
                overlay.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
